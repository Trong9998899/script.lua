-- [4] HỆ THỐNG RENDER GIAO DIỆN (CHỐNG LỖI)
local TabFrames = {}
local isFirstTab = true

for tabName, featureList in pairs(HubData) do
    -- Nút bấm Sidebar
    local TabBtn = Instance.new("TextButton", Sidebar)
    TabBtn.Size = UDim2.new(1, 0, 0, 35); TabBtn.Text = tabName; TabBtn.Font = Enum.Font.GothamSemibold; TabBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    TabBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 40); Instance.new("UICorner", TabBtn).CornerRadius = UDim.new(0, 6)

    -- Khung chứa chức năng bên phải
    local ScrollContent = Instance.new("ScrollingFrame", ContentArea)
    ScrollContent.Size = UDim2.new(1, 0, 1, 0); ScrollContent.BackgroundTransparency = 1; ScrollContent.ScrollBarThickness = 4
    ScrollContent.Visible = isFirstTab; isFirstTab = false
    Instance.new("UIListLayout", ScrollContent).Padding = UDim.new(0, 8)
    TabFrames[tabName] = ScrollContent

    -- Bấm Tab nào, hiện Tab đó
    TabBtn.MouseButton1Click:Connect(function()
        for _, frame in pairs(TabFrames) do frame.Visible = false end
        ScrollContent.Visible = true
        for _, btn in pairs(Sidebar:GetChildren()) do
            if btn:IsA("TextButton") then btn.BackgroundColor3 = Color3.fromRGB(30, 30, 40) end
        end
        TabBtn.BackgroundColor3 = Color3.fromRGB(80, 40, 200) -- Highlight Tab đang chọn
    end)

    if ScrollContent.Visible then TabBtn.BackgroundColor3 = Color3.fromRGB(80, 40, 200) end

    -- Tạo công tắc (Toggle) cho từng chức năng
    for _, feature in ipairs(featureList) do
        local labelName, configKey = feature[1], feature[2]
        getgenv().Config[configKey] = false

        local ToggleFrame = Instance.new("Frame", ScrollContent)
        ToggleFrame.Size = UDim2.new(1, -15, 0, 40); ToggleFrame.BackgroundColor3 = Color3.fromRGB(25, 25, 30); Instance.new("UICorner", ToggleFrame)

        local Label = Instance.new("TextLabel", ToggleFrame)
        Label.Size = UDim2.new(1, -60, 1, 0); Label.Position = UDim2.new(0, 15, 0, 0); Label.Text = labelName; Label.TextColor3 = Color3.fromRGB(220, 220, 220); Label.BackgroundTransparency = 1; Label.TextXAlignment = 0; Label.Font = Enum.Font.Gotham

        local SwitchBtn = Instance.new("TextButton", ToggleFrame)
        SwitchBtn.Size = UDim2.new(0, 40, 0, 20); SwitchBtn.Position = UDim2.new(1, -55, 0.5, -10); SwitchBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 60); SwitchBtn.Text = ""; Instance.new("UICorner", SwitchBtn).CornerRadius = UDim.new(1, 0)
        
        local Dot = Instance.new("Frame", SwitchBtn)
        Dot.Size = UDim2.new(0, 16, 0, 16); Dot.Position = UDim2.new(0, 2, 0.5, -8); Dot.BackgroundColor3 = Color3.fromRGB(255, 255, 255); Instance.new("UICorner", Dot).CornerRadius = UDim.new(1, 0)

        SwitchBtn.MouseButton1Click:Connect(function()
            getgenv().Config[configKey] = not getgenv().Config[configKey]
            TS:Create(SwitchBtn, TweenInfo.new(0.2), {BackgroundColor3 = getgenv().Config[configKey] and Color3.fromRGB(0, 255, 150) or Color3.fromRGB(60, 60, 60)}):Play()
            TS:Create(Dot, TweenInfo.new(0.2), {Position = getgenv().Config[configKey] and UDim2.new(1, -18, 0.5, -8) or UDim2.new(0, 2, 0.5, -8)}):Play()
        end)
    end
end

-- [5] LOGIC THỰC THI GAME CỐT LÕI (BRAIN)
task.spawn(function()
    while task.wait() do
        -- Gom Quái (Bring Mobs)
        if getgenv().Config.BringMobs then
            pcall(function()
                for _, mob in pairs(game.Workspace.Enemies:GetChildren()) do
                    if mob:FindFirstChild("HumanoidRootPart") and mob.Humanoid.Health > 0 then
                        mob.HumanoidRootPart.CFrame = Player.Character.HumanoidRootPart.CFrame * CFrame.new(0, 0, -5)
                        mob.HumanoidRootPart.CanCollide = false
                    end
                end
            end)
        end

        -- Né sát thương quái (Dodge Mobs)
        if getgenv().Config.DodgeMobs then
            pcall(function()
                if Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") then
                    -- Liên tục dịch chuyển nhân vật lên trên một khoảng rất nhỏ để quái đánh hụt
                    Player.Character.HumanoidRootPart.CFrame = Player.Character.HumanoidRootPart.CFrame * CFrame.new(0, 0.5, 0)
                end
            end)
        end

        -- Fix Lag & Đổi Bầu Trời
        if getgenv().Config.SkyFix then
            pcall(function()
                Lighting.GlobalShadows = false
                if not Lighting:FindFirstChild("OptimizedSky") then
                    local sky = Instance.new("Sky", Lighting)
                    sky.Name = "OptimizedSky"
                    sky.SkyboxBk = "rbxassetid://144404646" -- Bầu trời hình ảnh nhẹ
                    sky.SkyboxDn = "rbxassetid://144404646"
                    sky.SkyboxFt = "rbxassetid://144404646"
                    sky.SkyboxLf = "rbxassetid://144404646"
                    sky.SkyboxRt = "rbxassetid://144404646"
                    sky.SkyboxUp = "rbxassetid://144404646"
                end
            end)
        end
    end
end)

